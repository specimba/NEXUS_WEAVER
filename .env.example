# NEXUS Visual Weaver — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# In the sandbox, .env may be wiped on reset — secrets.ts (committed to git)
# provides hardcoded fallbacks so the pipeline keeps working.
# In production, use a real secrets manager (Vault, AWS Secrets Manager, etc.).
# =============================================================================

# Database (SQLite, local file)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Modal GPU — set to true to use Modal as the primary image generation path
MODAL_USE=true

# Modal FLUX.2 Klein 9B endpoints (L40S GPU)
MODAL_FLUX2_URL=https://specimba--nexus-flux2-klein9b-nexusflux2generator-generate.modal.run
MODAL_FLUX2_READY=true

# Modal timeouts (seconds)
MODAL_COLD_START_TIMEOUT=300
MODAL_WARM_TIMEOUT=120

# Qwen3.6-27B-AEON brain endpoint (B200 GPU, EU West)
MODAL_BRAIN_URL=https://specimba--ep-qwen3-6-27b-aeon-ultimate-uncensored-bf16-server.eu-west.modal.direct
MODAL_BRAIN_MODEL=AEON-7/Qwen3.6-27B-AEON-Ultimate-Uncensored-BF16

# Modal auth tokens (get from Modal Dashboard → Settings → API Tokens)
MODAL_TOKEN_ID=ak-your-token-id
MODAL_TOKEN_SECRET=as-your-token-secret

# Modal proxy tokens (for Auto Endpoints — create via: modal workspace proxy-tokens create)
MODAL_PROXY_KEY=wk-your-proxy-key
MODAL_PROXY_SECRET=ws-your-proxy-secret

# HuggingFace token (for gated model downloads)
HF_TOKEN=hf_your_hf_token

# Video I2V backends (deployed as separate Modal apps)
MODAL_WAN22_URL=https://specimba--nexus-wan22-i2v-nexuswan22generator-web-app.modal.run
MODAL_LTX23_URL=https://specimba--nexus-ltx23-i2v-nexusltx23generator-web-app.modal.run
