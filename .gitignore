# =============================================================================
# NEXUS Visual Weaver — Professional .gitignore
# =============================================================================
# This .gitignore keeps the GitHub repo lean: only source code, modal-apps,
# prisma schema, and essential config are tracked. Generated artifacts, large
# binaries, databases, logs, and user uploads are excluded.
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ── Production builds ────────────────────────────────────────────────────────
/build

# ── Database (SQLite — regenerated by prisma db push, never committed) ───────
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# ── Environment files (volatile in sandbox — secrets.ts is the fallback) ─────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
dev.log
dev.out.log
server.log

# ── Generated gallery images + videos (regenerated per run) ──────────────────
public/gallery/*
!public/gallery/.gitkeep

# ── User uploads (large reference files, never part of source) ───────────────
upload/

# ── Skills directory (separate concerns) ─────────────────────────────────────
/skills/

# ── Misc ─────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel
.claude
.z-ai-config
local-*
test
prompt

# ── OS / Editor ──────────────────────────────────────────────────────────────
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ── Agent context (generated by subagents) ───────────────────────────────────
/agent-ctx/
tool-results/
preview-*.png
